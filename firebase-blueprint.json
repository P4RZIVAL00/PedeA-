{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "store", "delivery"] },
        "fcmTokens": { "type": "array", "description": "List of FCM tokens for push notifications" }
      },
      "required": ["uid", "name", "phone", "role"]
    },
    "Store": {
      "title": "Store",
      "description": "Merchant profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["restaurant", "market", "pharmacy", "other"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "ownerId": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "category", "address", "phone", "ownerId"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "name", "price", "storeId"]
    },
    "Order": {
      "title": "Order",
      "description": "Delivery order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "storeId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "deliveryAddress": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["pix", "cash", "mercadopago"] },
        "status": { "type": "string", "enum": ["created", "awaiting_payment", "paid", "accepted_by_store", "preparing", "ready_for_delivery", "accepted_by_driver", "out_for_delivery", "delivered", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "driverId": { "type": "string" }
      },
      "required": ["id", "customerId", "storeId", "items", "total", "deliveryAddress", "paymentMethod", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store profiles"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Products within a store"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders"
    },
    "/orders/{orderId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages related to an order"
    }
  }
}
